#!/usr/bin/env bash

DOTFILES_ROOT=$(pwd -P)

set -e

echo ''

info () {
  printf "\r  [ \033[00;34m..\033[0m ] $1\n"
}

user () {
  printf "\r  [ \033[0;33m??\033[0m ] $1\n"
}

success () {
  printf "\r\033[2K  [ \033[00;32mOK\033[0m ] $1\n"
}

print_diff_if_changed () {
  local diff_mode=$1 old_path=$2 new_path=$3 description=$4
  local status
  local diff_old_path="$old_path"
  local cleanup_dir=

  info "diff for $description"

  if [ "$diff_mode" = "dir" ] && [ ! -d "$diff_old_path" ]; then
    cleanup_dir=$(mktemp -d)
    diff_old_path="$cleanup_dir"
  elif [ "$diff_mode" != "dir" ] && [ ! -f "$diff_old_path" ]; then
    diff_old_path=/dev/null
  fi

  set +e
  git --no-pager diff --no-index --color=always -- "$diff_old_path" "$new_path"
  status=$?
  set -e

  if [ -n "$cleanup_dir" ]; then
    rm -rf "$cleanup_dir"
  fi

  if [ $status -eq 0 ]; then
    info "no changes in $description"
  elif [ $status -eq 1 ]; then
    success "printed diff for $description"
  else
    fail "Failed to diff $description"
  fi
}

show_help () {
  cat <<EOF
Usage: ./bootstrap [component ...]

Install dotfiles and related tool configuration.

Components:
  dotfiles    Application configs under config/
  shell       Bash and Zsh rc files
  pixi        Pixi installation and global packages
  tmux_conf   Tmux configuration
  opencode    OpenCode configuration
  claude      Claude configuration
  codex       Codex configuration
  skills      Install skills recorded in ./my-skills.sh
  codex_sync  Sync ~/.codex into repo/codex with sanitization

Examples:
  ./bootstrap
  ./bootstrap dotfiles claude
  ./bootstrap skills
  ./bootstrap codex_sync
  ./bootstrap --help
EOF
}

fail () {
  printf "\r\033[2K  [\033[0;31mFAIL\033[0m] $1\n"
  echo ''
  exit
}

link_file () {
  local src=$1 dst=$2

  local overwrite= backup= skip=
  local action=

  # If the destination file exists, ask the user what to do
  # `-f`: file, `-d`: directory, `-L`: symbolic link
  if [ -f "$dst" -o -d "$dst" -o -L "$dst" ]
  then

    if [ "$overwrite_all" == "false" ] && [ "$backup_all" == "false" ] && [ "$skip_all" == "false" ]
    then

      local currentSrc="$(readlink $dst)"

      if [ "$currentSrc" == "$src" ]
      then

        skip=true;

      else

        user "File already exists: $dst ($(basename "$src")), what do you want to do?\n\
        [s]kip, [S]kip all, [o]verwrite, [O]verwrite all, [b]ackup, [B]ackup all?"
        read -n 1 action

        case "$action" in
          o )
            overwrite=true;;
          O )
            overwrite_all=true;;
          b )
            backup=true;;
          B )
            backup_all=true;;
          s )
            skip=true;;
          S )
            skip_all=true;;
          * )
            ;;
        esac

      fi

    fi

    overwrite=${overwrite:-$overwrite_all}
    backup=${backup:-$backup_all}
    skip=${skip:-$skip_all}

    if [ "$overwrite" == "true" ]
    then
      rm -rf "$dst"
      success "removed $dst"
    fi

    if [ "$backup" == "true" ]
    then
      mv "$dst" "${dst}.backup"
      success "moved $dst to ${dst}.backup"
    fi

    if [ "$skip" == "true" ]
    then
      success "skipped $src"
    fi
  fi

  if [ "$skip" != "true" ]  # "false" or empty
  then
    ln -s "$1" "$2"
    success "linked $1 to $2"
  fi
}

if [ $# -gt 0 ]; then
    case "$1" in
        -h|--help|help)
            show_help
            exit 0
            ;;
    esac
fi

if [ -n "$BASH_VERSION" ]; then
    shell_rc=$(realpath "${BASH_SOURCE[0]}")
    shell="bash"
elif [ -n "$ZSH_VERSION" ]; then
    shell_rc=$(realpath "$0")
    shell="zsh"
else
    fail "Unknown shell: $current_shell"
fi

info "Shell: $shell"
info "Shell RC: $shell_rc"
info "DOTFILES_ROOT: $DOTFILES_ROOT"

install_dotfiles () {
    info 'installing dotfiles'

    local overwrite_all=false backup_all=false skip_all=false

    for src in $(find -H "$DOTFILES_ROOT/config" -mindepth 1 -maxdepth 1 -type d -not -path '*.git*')
    do
        dst="$HOME/.config/$(basename "${src%.*}")"
        link_file "$src" "$dst"
    done
}

backup_and_link_file() {
  local src=$1 dst=$2
  local backup_path current_src

  if [ -L "$dst" ]; then
    current_src="$(readlink "$dst")"
    if [ "$current_src" = "$src" ]; then
      success "already linked $src to $dst"
      return 0
    fi
  fi

  if [ -e "$dst" ] || [ -L "$dst" ]; then
    backup_path="${dst}.backup.$(date +%Y%m%d%H%M%S)"
    mv "$dst" "$backup_path"
    success "backed up $dst to $backup_path"
  fi

  ln -s "$src" "$dst"
  success "linked $src to $dst"
}

install_shell() {
    info 'installing shell rc files'

    backup_and_link_file "$DOTFILES_ROOT/.bashrc" "$HOME/.bashrc"
    backup_and_link_file "$DOTFILES_ROOT/.zshrc" "$HOME/.zshrc"
}

install_pixi() {
    info 'installing pixi'

    local overwrite_all=false backup_all=false skip_all=false
    pixi_cmd=pixi

    # Install pixi if not installed
    if ! command -v pixi &> /dev/null; then
        curl -fsSL https://pixi.sh/install.sh | $shell
        pixi_cmd=$HOME/.pixi/bin/pixi
        success "Pixi installed"
    else
        info "Pixi is already installed"
    fi

    # Install global pixi packages
    pixi_manifest_dir=$HOME/.pixi/manifests
    mkdir -p $pixi_manifest_dir
    link_file "$DOTFILES_ROOT/pixi/pixi-global.toml" "$pixi_manifest_dir/pixi-global.toml"
    $pixi_cmd global sync

    # Run post-install hooks
    run_pixi_post_install
}

run_pixi_post_install() {
    local post_install_file="$DOTFILES_ROOT/pixi/post-install.sh"

    if [ ! -f "$post_install_file" ]; then
        return 0
    fi

    # Source the post-install file to load hook functions
    source "$post_install_file"

    # Run post_install_* functions for installed commands
    info 'running post-install hooks'
    local func cmd
    for func in $(declare -F | awk '{print $3}' | grep '^post_install_'); do
        cmd="${func#post_install_}"

        if ! command -v "$cmd" &> /dev/null; then
            info "skipping $cmd (not installed)"
            continue
        fi

        info "running post-install hook for $cmd"
        if "$func"; then
            success "$cmd post-install done"
        else
            info "warning: $cmd post-install failed (may need manual setup)"
        fi
    done

    # Run install_* functions for missing commands
    info 'running standalone tool installers'
    for func in $(declare -F | awk '{print $3}' | grep '^install_'); do
        cmd="${func#install_}"

        if command -v "$cmd" &> /dev/null; then
            info "$cmd already installed"
            continue
        fi

        info "installing $cmd"
        if "$func"; then
            success "$cmd installed"
        else
            info "warning: $cmd installation failed (may need manual setup)"
        fi
    done
}

install_tmux_conf() {
    info 'installing tmux config'

    local overwrite_all=false backup_all=false skip_all=false

    src="$DOTFILES_ROOT/tmux/.tmux.conf"
    dst="$HOME/.tmux.conf"
    link_file "$src" "$dst"

    src="$DOTFILES_ROOT/.tmux.conf.local"
    dst="$HOME/.tmux.conf.local"
    link_file "$src" "$dst"
}

install_opencode() {
    info 'installing opencode'

    local overwrite_all=false backup_all=false skip_all=false
    local src_dir="$DOTFILES_ROOT/opencode"
    local dst_dir="$HOME/.config/opencode"

    info 'installing opencode configuration'

    # Ensure target directory exists
    mkdir -p "$dst_dir"

    # Link all files and directories from opencode to ~/.config/opencode
    for item in "$src_dir"/*; do
        if [ -e "$item" ]; then
            local name=$(basename "$item")
            local src="$item"
            local dst="$dst_dir/$name"

            # Copy tools directory instead of symlinking so custom tools
            # can resolve @opencode-ai/plugin from the config node_modules
            if [ "$name" = "tools" ] && [ -d "$src" ]; then
                mkdir -p "$dst"
                for toolfile in "$src"/*; do
                    if [ -e "$toolfile" ]; then
                        local toolname=$(basename "$toolfile")
                        local dstfile="$dst/$toolname"
                        if [ -L "$dstfile" ]; then
                            rm "$dstfile"
                        elif [ -f "$dstfile" ]; then
                            # Only copy if source is newer
                            if [ "$toolfile" -nt "$dstfile" ]; then
                                cp "$toolfile" "$dstfile"
                                success "updated $dstfile"
                            else
                                success "skipped $dstfile (up to date)"
                            fi
                            continue
                        fi
                        cp "$toolfile" "$dstfile"
                        success "copied $toolfile to $dstfile"
                    fi
                done
            else
                link_file "$src" "$dst"
            fi
        fi
    done
}

install_claude() {
    info 'installing claude configuration'

    local overwrite_all=false backup_all=false skip_all=false
    local src_dir="$DOTFILES_ROOT/claude"
    local dst_dir="$HOME/.claude"

    # Iterate through all items in claude directory
    for item in "$src_dir"/*; do
        if [ -e "$item" ]; then
            local name=$(basename "$item")
            local src="$item"
            local dst="$dst_dir/$name"

            # If destination already exists as a directory, link its contents
            if [ -d "$dst" ]; then
                for subitem in "$src"/*; do
                    if [ -e "$subitem" ]; then
                        local subname=$(basename "$subitem")
                        link_file "$subitem" "$dst/$subname"
                    fi
                done
            else
                # Otherwise, link the item directly
                link_file "$src" "$dst"
            fi
        fi
    done

    # TODO: Setup mcp
    # claude mcp add sequential-thinking -s user -- npx -y @modelcontextprotocol/server-sequential-thinkin
}

install_codex() {
    info 'installing codex configuration'

    local overwrite_all=false backup_all=false skip_all=false
    local src_dir="$DOTFILES_ROOT/codex"
    local dst_dir="$HOME/.codex"

    mkdir -p "$dst_dir"

    # Iterate through all items in codex directory
    for item in "$src_dir"/*; do
        if [ -e "$item" ]; then
            local name=$(basename "$item")
            local src="$item"
            local dst="$dst_dir/$name"

            # If destination already exists as a directory, link its contents
            if [ -d "$dst" ]; then
                for subitem in "$src"/*; do
                    if [ -e "$subitem" ]; then
                        local subname=$(basename "$subitem")
                        link_file "$subitem" "$dst/$subname"
                    fi
                done
            else
                # Otherwise, link the item directly
                link_file "$src" "$dst"
            fi
        fi
    done
}

install_codex_sync() {
    info 'syncing codex configuration from ~/.codex to dotfiles'

    local src_dir="$HOME/.codex"
    local dst_dir="$DOTFILES_ROOT/codex"
    local tmp_config
    local tmp_prompts

    mkdir -p "$dst_dir"
    mkdir -p "$dst_dir/prompts"

    if [ ! -f "$src_dir/config.toml" ]; then
        fail "Cannot sync Codex: $src_dir/config.toml not found"
    fi

    tmp_config=$(mktemp)
    python3 "$DOTFILES_ROOT/scripts/sanitize_codex_config.py" \
        "$src_dir/config.toml" \
        "$tmp_config"
    print_diff_if_changed "file" "$dst_dir/config.toml" "$tmp_config" "codex config.toml"
    mv "$tmp_config" "$dst_dir/config.toml"
    success "synced and sanitized $dst_dir/config.toml"

    if [ -d "$src_dir/prompts" ]; then
        tmp_prompts=$(mktemp -d)
        for item in "$src_dir/prompts"/*; do
            if [ -e "$item" ]; then
                cp -R "$item" "$tmp_prompts/"
            fi
        done
        print_diff_if_changed "dir" "$dst_dir/prompts" "$tmp_prompts" "codex prompts"
        find "$dst_dir/prompts" -mindepth 1 -maxdepth 1 -exec rm -rf {} +
        for item in "$src_dir/prompts"/*; do
            if [ -e "$item" ]; then
                cp -R "$item" "$dst_dir/prompts/"
            fi
        done
        rm -rf "$tmp_prompts"
        success "synced prompts to $dst_dir/prompts"
    else
        info "No prompts directory at $src_dir/prompts, skipped"
    fi
}

install_skills() {
    info 'installing skills'
    "$DOTFILES_ROOT/my-skills.sh"
}

git submodule update --init --recursive

# Parameter handling: install specific component or all
if [ $# -eq 0 ]; then
    # No arguments, install everything
    install_dotfiles
    install_shell
    install_pixi
    install_tmux_conf
    install_opencode
    install_claude
    install_codex
    install_skills
else
    # Install specified components
    for target in "$@"; do
        func="install_$target"
        if type "$func" &>/dev/null; then
            "$func"
        else
            show_help
            fail "Unknown target: $target"
        fi
    done
fi

# TODO: Git config

# Mac specific stuff here
if [ "$(uname -s)" == "Darwin" ]
then
    # TODO:
    echo
fi

echo ''
echo '  All installed!'
