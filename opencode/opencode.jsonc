{
  "$schema": "https://opencode.ai/config.json",

  "plugin": [
    // "@tarquinen/opencode-dcp@latest",
    // "opencode-pty"
  ],

  "instructions": ["CLAUDE.md"],

  "permission": {
    "bash": {
      "*": "allow",
      "sudo *": "ask",
      "su *": "ask",
      "passwd *": "ask",
      "shutdown *": "deny",
      "reboot *": "deny",
      "halt *": "deny",
      "poweroff *": "deny",
      "systemctl reboot": "deny",
      "systemctl poweroff": "deny",
      "systemctl halt": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "dd if=/dev/zero of=/dev/*": "deny",
      "mkfs *": "deny",
      "fdisk *": "deny",
      "parted *": "deny",
      // "git commit *": "ask",
      // "git push *": "ask",
      // "git merge *": "ask",
      // "git rebase *": "ask",
      // "git reset *": "ask",
      // "git revert *": "ask",
      // "git cherry-pick *": "ask",
      // "git tag *": "ask",
      "chmod 777 *": "deny",
      "chown root *": "deny"
    },
    "edit": "allow",
    "webfetch": "allow",
    "external_directory": "allow"
  },

  "model": "github-copilot/gpt-4.1",

  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "litellm",
      "options": {
        "baseURL": "http://127.0.0.1:4000/v1",
        "apiKey": "sk-1234"
      },
      "models": {
        "kimi-k2.6": {
          "name": "Kimi K2.6",
          "attachment": true,
          "reasoning": true,
          "interleaved": { "field": "reasoning_content" },
          "limit": {
            "context": 260000,
            "output": 0
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek v4 Pro",
          "attachment": true,
          "reasoning": true,
          "interleaved": { "field": "reasoning_content" },
          "limit": {
            "context": 1000000,
            "output": 0
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "variants": {
            "high": { "reasoningEffort": "high" },
            "max": { "reasoningEffort": "max" }
          }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek v4 Flash",
          "attachment": true,
          "reasoning": true,
          "interleaved": { "field": "reasoning_content" },
          "limit": {
            "context": 1000000,
            "output": 0
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "variants": {
            "high": { "reasoningEffort": "high" },
            "max": { "reasoningEffort": "max" }
          }
        },
        "minimax-m2.7": {
          "name": "MiniMax M2.7",
          "attachment": true,
          "reasoning": true,
          "interleaved": { "field": "reasoning_content" },
          "limit": {
            "context": 204800,
            "output": 0
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "glm-5.1": {
          "name": "GLM-5.1",
          "attachment": true,
          "reasoning": true,
          "interleaved": { "field": "reasoning_content" },
          "limit": {
            "context": 204800,
            "output": 0
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "mimo-v2.5-pro": {
          "name": "Mimo v2.5 Pro",
          "attachment": true,
          "reasoning": true,
          "interleaved": { "field": "reasoning_content" },
          "limit": {
            "context": 1000000,
            "output": 0
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "variants": {
            "high": { "reasoningEffort": "high" }
          }
        },
        "gpt-5.5": {
          "name": "GPT-5.5",
          "attachment": true,
          "reasoning": true,
          "interleaved": { "field": "reasoning_content" },
          "limit": {
            "context": 400000,
            "output": 0
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "variants": {
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        }
      }
    },
    "litellm-gpt": {
      "npm": "@ai-sdk/openai",
      "name": "litellm-gpt",
      "options": {
        "baseURL": "http://127.0.0.1:4000/v1",
        "apiKey": "sk-1234"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5",
          "attachment": true,
          "reasoning": true,
          "interleaved": { "field": "reasoning_content" },
          "limit": {
            "context": 400000,
            "output": 0
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "variants": {
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        }
      }
    }
  },

  "lsp": {
    "lua-ls": {
      "disabled": true
    },
    "emmylua": {
      "command": ["emmylua_ls"],
      "extensions": [".lua"]
    }
  },

  "mcp": {}
}
