{
  "$schema": "https://opencode.ai/config.json",

  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "opencode-pty"
  ],

  "instructions": ["CLAUDE.md"],

  "permission": {
    "bash": {
      "*": "allow",
      "sudo *": "ask",
      "su *": "ask",
      "passwd *": "ask",
      "shutdown *": "deny",
      "reboot *": "deny",
      "halt *": "deny",
      "poweroff *": "deny",
      "systemctl reboot": "deny",
      "systemctl poweroff": "deny",
      "systemctl halt": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "dd if=/dev/zero of=/dev/*": "deny",
      "mkfs *": "deny",
      "fdisk *": "deny",
      "parted *": "deny",
      // "git commit *": "ask",
      // "git push *": "ask",
      // "git merge *": "ask",
      // "git rebase *": "ask",
      // "git reset *": "ask",
      // "git revert *": "ask",
      // "git cherry-pick *": "ask",
      // "git tag *": "ask",
      "chmod 777 *": "deny",
      "chown root *": "deny"
    },
    "edit": "allow",
    "webfetch": "allow",
    "external_directory": "allow"
  },

  "agent": {
    "yolo": {
      "mode": "primary",
      "description": "High-trust primary agent that skips approval prompts for bash commands and external file access",
      "permission": {
        "bash": "allow",
        "external_directory": "allow"
      }
    }
  },

  "default_agent": "yolo",

  "model": "cpa/gpt-5.4",

  "provider": {
    "cpa": {
      "npm": "@ai-sdk/openai",
      "name": "cpa",
      "options": {
        "baseURL": "{env:CPA_BASE_URL}",
        // API key for local cliproxy service (placeholder/test key)
        "apiKey": "{env:CPA_API_KEY}"
      },
      "models": {
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "options": {
            "reasoningEffort": "high"
          },
          "limit": {
            "context": 200000,
            "output": 0
          },
          "variants": {
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "options": {
            "reasoningEffort": "high"
          },
          "limit": {
            "context": 200000,
            "output": 0
          },
          "variants": {
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini",
          "options": {
            "reasoningEffort": "high"
          },
          "variants": {
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        }
      }
    }
  },

  "lsp": {
    "lua-ls": {
      "disabled": true
    },
    "emmylua": {
      "command": ["emmylua_ls"],
      "extensions": [".lua"]
    }
  },

  "mcp": {
    // Exa AI Web Search MCP Server
    // "exa": {
    //   "type": "remote",
    //   "url": "https://mcp.exa.ai/mcp?tools=web_search_exa"
    // }
  }
}
